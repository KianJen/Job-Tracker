# ── Local dev (npm run dev) ─────────────────────────────────────────────────
# Base URL of the Job Tracker backend API (no trailing slash).
# When running npm run dev, the Vite dev server doesn't go through nginx,
# so set this to point directly at the API.
VITE_API_URL=http://localhost:8000

# ── Docker Compose deployment ────────────────────────────────────────────────
# IP or hostname of the machine running docker compose.
# Used to build correct file-download URLs and CORS headers.
# Leave unset to default to "localhost" (same-machine access only).
HOST_IP=192.168.1.x
