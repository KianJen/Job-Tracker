# Postgres connection (async driver)
DATABASE_URL=postgresql+asyncpg://jobtracker:jobtracker@localhost:5432/jobtracker

# Garage / S3-compatible object storage
S3_ENDPOINT_URL=http://localhost:3900
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=job-tracker-docs
S3_REGION=garage

# URL the browser uses to reach this API (used to build file links)
PUBLIC_BASE_URL=http://localhost:8000

# Comma-separated list is also accepted by pydantic via JSON, e.g. ["http://localhost:5173"]
CORS_ORIGINS=["http://localhost:5173"]

# Max upload size in bytes (10 MB)
MAX_UPLOAD_BYTES=10485760
